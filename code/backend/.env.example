# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Database (01-data-model.md) ---
# The running application connects as the restricted `app_user` role — created by
# migrations/000_create_app_role.sql, NOT by Docker Compose. This role owns nothing and
# is not a superuser, which is what makes audit_log's REVOKE/GRANT (Section 8.2) a real
# boundary rather than a no-op: PostgreSQL superusers and table owners always bypass
# GRANT/REVOKE checks on objects they own/superuser over. Never point this at the
# docker-compose.yml bootstrap "postgres" role.
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/edutech_dev

# Separate database for the test suite (tests/setup.js reads this when NODE_ENV=test).
# Created automatically on first `docker compose up` via code/postgres-init/01-create-test-db.sql.
TEST_DATABASE_URL=postgresql://app_user:app_password@localhost:5432/edutech_test

# --- Migrations only (scripts/migrate.js) — never read by the running server ---
# Table/role creation and the audit_log REVOKE/GRANT require privileges app_user
# deliberately lacks. These connect as docker-compose.yml's bootstrap "postgres" role.
ADMIN_DATABASE_URL=postgresql://postgres:postgres_admin_password@localhost:5432/edutech_dev
ADMIN_TEST_DATABASE_URL=postgresql://postgres:postgres_admin_password@localhost:5432/edutech_test

# --- JWT (03-security-architecture.md Section 2) ---
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=replace_with_a_long_random_string
# Access tokens are short-lived by design (03-security-architecture.md Section 2.1).
# This is intentionally NOT environment-configurable beyond this — the 15m value
# is hardcoded in src/config, consistent with the argon2 cost-factor reasoning
# in 03-security-architecture.md Section 1.2 (security-critical values that are
# too easy to weaken via env var copy-paste are hardcoded instead).

# --- Server ---
PORT=4000
NODE_ENV=development

# --- CORS (03-security-architecture.md Section 6.1) ---
# Exactly one trusted origin per environment — never a hardcoded list, never a wildcard.
# Local dev: http://localhost:5173 (Vite default)
# Production: the real deployed frontend URL
FRONTEND_URL=http://localhost:5173

# --- Seed script (03-security-architecture.md Section 0.1) ---
# Used only by scripts/create-admin.js, never read by the running server.
# Not required in the running app's .env — set as CLI args when the script is run.

# --- Database privileges (03-security-architecture.md Section 8.2, added Step 6) ---
# audit_log has UPDATE/DELETE revoked from app_user at setup time — see
# migrations/000_create_app_role.sql (creates the restricted role) and
# migrations/015_create_audit_log.sql (the actual REVOKE/GRANT, immediately after CREATE TABLE).
# This is a one-time DB-level privilege, not an env var — nothing to configure here.
